# ROS 2 integration-test image: runs the full pytest suite (sim core +
# rclpy bridge tests) against ROS 2 Jazzy. Build/run via
# scripts/run_ros2_tests.sh.
FROM ros:jazzy

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

# venv with system site packages so pip-installed mujoco coexists with the
# apt-installed rclpy stack
RUN python3 -m venv --system-site-packages /opt/venv
ENV PATH=/opt/venv/bin:$PATH

RUN pip install --no-cache-dir "mujoco>=3.6" numpy "pytest>=8,<9"

WORKDIR /ws
COPY . .

# /ros_entrypoint.sh (base image) sources /opt/ros/jazzy/setup.bash first
CMD ["pytest", "tests/", "-v", "--color=yes"]
